# Copy this file to ".env" (in the project root) and fill in your key.
# .env is gitignored, so your key never gets committed.
#
#   cp .env.example .env
#
# Maestro loads .env automatically on startup. Leave everything blank to run
# fully offline on the built-in simulation brain (no key needed).

# --- Google Gemini (free key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- OpenAI (alternative to Gemini) ---
# OPENAI_API_KEY=

# Optional: which model to use (default: gemini-2.5-flash for Gemini).
# Leave blank to use the built-in default.
MAESTRO_MODEL=gemini-2.5-flash

# Optional: max concurrent model calls. Lower to 1 or 2 if a free tier
# rate-limits you (429 errors).
MAESTRO_MAX_CONCURRENCY=2
